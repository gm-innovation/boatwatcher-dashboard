{
  "name": "dock-check-desktop",
  "repository": "gm-innovation/boatwatcher-dashboard",
  "private": true,
  "version": "1.3.67",
  "description": "Dock Check Desktop and web dashboard for workforce, access, and device operations.",
  "author": "Dock Check",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:desktop": "vite build --mode electron",
    "lint": "eslint .",
    "preview": "vite preview",
    "server:start": "npm --prefix server run start",
    "server:dev": "npm --prefix server run dev",
    "local-server:dev": "electron electron/local-server-main.js",
    "electron:dev": "wait-on tcp:8080 && electron .",
    "desktop:dev": "concurrently -k \"npm run server:dev\" \"npm run dev\" \"npm run electron:dev\"",
    "build:electron": "npm run build:desktop && electron-builder --publish never",
    "build:electron:publish": "npm run build:desktop && electron-builder --config electron-builder.release.yml --publish always",
    "prebuild:local-server": "node scripts/verify-local-server-deps.cjs",
    "build:local-server": "electron-builder --config electron-builder.server.yml --publish never",
    "build:local-server:dir": "electron-builder --config electron-builder.server.yml --dir --publish never",
    "build:local-server:publish": "electron-builder --config electron-builder.release.server.yml --publish always",
    "local-server:uninstall": "powershell -ExecutionPolicy Bypass -File scripts/uninstall-local-server.ps1"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
